{
    "name": "@thinremote/thinr-cli",
    "version": "1.0.2",
    "description": "CLI for ThinRemote - Remote management for IoT devices",
    "main": "bin/thinr.js",
    "bin": {
        "thinr": "bin/thinr.js"
    },
    "scripts": {
        "start": "node bin/thinr.js",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "typecheck": "tsc",
        "test": "node --test 'tests/**/*.test.js'"
    },
    "keywords": [
        "cli",
        "iot",
        "remote",
        "management",
        "thing",
        "thinger"
    ],
    "author": "ThinRemote",
    "license": "MIT",
    "dependencies": {
        "@inquirer/prompts": "^7.5.3",
        "@modelcontextprotocol/sdk": "^1.29.0",
        "axios": "^1.10.0",
        "chalk": "^5.4.1",
        "commander": "^14.0.0",
        "conf": "^14.0.0",
        "figlet": "^1.8.1",
        "jsonwebtoken": "^9.0.2",
        "open": "^10.1.2",
        "ora": "^8.2.0",
        "ws": "^8.18.2"
    },
    "type": "module",
    "engines": {
        "node": ">=14.16"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.6.0",
        "eslint": "^10.2.0",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.5.0",
        "prettier": "^3.8.3",
        "typescript": "^6.0.2"
    }
}

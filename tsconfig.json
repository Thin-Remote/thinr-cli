{
    "compilerOptions": {
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "target": "ES2022",
        "allowJs": true,
        "checkJs": false,
        "noEmit": true,
        "noImplicitAny": false,
        "strict": false,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "types": ["node"]
    },
    "include": ["bin/**/*.js", "commands/**/*.js", "lib/**/*.js"],
    "exclude": ["node_modules"]
}
